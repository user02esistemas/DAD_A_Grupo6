# ─── Configuración de Base de Datos ───────────────────────────
# Variables individuales para local (Docker)
DB_NAME=restaurant_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Para despliegue en Railway (usar URL completa)
DATABASE_URL=postgres://usuario:password@host:puerto/nombre_db

# ─── Configuración de Django ──────────────────────────────────
DEBUG=False
SECRET_KEY=django-insecure-CAMBIA-ESTA-CLAVE-EN-PRODUCCION-xyz123
ALLOWED_HOSTS=*

# ─── JWT Settings (Opcional por ahora) ────────────────────────
JWT_SECRET_KEY=cambia-esto-por-un-hash-seguro
